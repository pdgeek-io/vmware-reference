# Source this file before running Terraform or PowerCLI scripts
# Usage: source config/powerstore.env

export POWERSTORE_ENDPOINT="powerstore.lab.example.com"
export POWERSTORE_USERNAME="admin"
export POWERSTORE_PASSWORD="CHANGE_ME"

# Optional: PowerStore REST API base URL (auto-derived from endpoint)
# export POWERSTORE_API_URL="https://${POWERSTORE_ENDPOINT}/api/version"

# vCenter credentials (if not using tfvars)
export VSPHERE_SERVER="vcenter.lab.example.com"
export VSPHERE_USER="administrator@vsphere.local"
export VSPHERE_PASSWORD="CHANGE_ME"
