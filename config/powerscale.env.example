# PowerScale connection settings for research storage
# Copy to powerscale.env and update with actual values
export POWERSCALE_ENDPOINT="powerscale.lab.example.com"
export POWERSCALE_USER="admin"
export POWERSCALE_PASSWORD="changeme"

# AD / Entra ID join credentials (for initial setup)
export AD_JOIN_USER="admin@campus.lab.example.com"
export AD_JOIN_PASSWORD="changeme"
