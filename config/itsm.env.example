# =============================================================================
# pdgeek.io — ITSM Integration Settings
# Copy to itsm.env and update with actual values
#
# Set ITSM_PROVIDER to activate an adapter:
#   "servicenow"  — ServiceNow REST API
#   "teamdynamix" — TeamDynamix (common in higher ed)
#   "generic"     — Generic webhook for any ITSM
# =============================================================================

export ITSM_PROVIDER="teamdynamix"

# Auto-approve requests without ITSM approval workflow (demo mode)
export AUTO_APPROVE="false"

# ── ServiceNow ──────────────────────────────────────────────────────
# export SERVICENOW_INSTANCE="university.service-now.com"
# export SERVICENOW_USER="api_user"
# export SERVICENOW_PASSWORD="changeme"
# export SERVICENOW_ASSIGNMENT_GROUP="IT Infrastructure"
# export SERVICENOW_WEBHOOK_TOKEN="your-webhook-token"

# ── TeamDynamix (TDX) ──────────────────────────────────────────────
export TDX_BASE_URL="https://university.teamdynamix.com"
export TDX_APP_ID="123"
export TDX_BEID="your-be-id"
export TDX_WEB_SERVICES_KEY="your-web-services-key"
export TDX_WEBHOOK_SECRET="your-hmac-secret"

# TDX ticket configuration (IDs vary by institution)
export TDX_TICKET_TYPE_SERVICE_REQUEST="682"
export TDX_TICKET_SOURCE_API="8"
export TDX_STATUS_NEW="432"
export TDX_STATUS_IN_PROCESS="433"
export TDX_STATUS_RESOLVED="434"
export TDX_STATUS_CANCELLED="435"
export TDX_PRIORITY_MEDIUM="31"
export TDX_ACCOUNT_ID="0"

# TDX custom attribute IDs (create these in TDX Admin → Custom Attributes)
# export TDX_ATTR_PDGEEK_ID="12345"
# export TDX_ATTR_DEPARTMENT="12346"
# export TDX_ATTR_GRANT_ID="12347"
# export TDX_ATTR_COST_CENTER="12348"

# TDX CMDB form IDs
# export TDX_FORM_VM="100"
# export TDX_FORM_STORAGE="101"
# export TDX_ASSET_STATUS_ACTIVE="9"
# export TDX_ASSET_STATUS_DISPOSED="14"

# ── Generic Webhook ────────────────────────────────────────────────
# export GENERIC_ITSM_WEBHOOK_URL="https://itsm.university.edu/api/webhooks/pdgeek"
# export GENERIC_ITSM_API_KEY="your-api-key"
# export WEBHOOK_TOKEN="your-inbound-webhook-token"
